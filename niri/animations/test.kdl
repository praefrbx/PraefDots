/*
Title: glide
Authors: Justin Garza <JGarza9788@gmail.com>
Desc: a softer Apple-like glide preset for niri.
Demo: ./demos/glide.gif
Notes:
- Smooth, polished, low-bounce motion.
- Open is slightly more luxurious than close.
- Uses custom shaders where niri supports them.
*/

animations {
    // Uncomment while tuning.
    slowdown 1.5


    window-open {
        duration-ms 260
        // close to a polished macOS-style ease-out feel
        curve "cubic-bezier" 0.22 1.0 0.36 1.0
    }

    window-close {
        duration-ms 180
        // quick, clean exit
        curve "cubic-bezier" 0.32 0.0 0.67 0.0
    }

    window-resize {
        // Resizes should feel soft but controlled.
        spring damping-ratio=1.0 stiffness=720 epsilon=0.0001
    }

// ***animations below do not use a shaders ***
// these are not required


    workspace-switch {
        // Smooth, composed, no bounce.
        spring damping-ratio=1.0 stiffness=760 epsilon=0.0001
    }
    
    horizontal-view-movement {
        // Main "camera glide" for scrollable movement.
        spring damping-ratio=1.0 stiffness=640 epsilon=0.0001
    }

    window-movement {
        // Individual windows shift with a slightly tighter response
        // than the camera, so it feels organized.
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    config-notification-open-close {
        // Less playful, more refined than the default underdamped feel.
        spring damping-ratio=1.0 stiffness=820 epsilon=0.001
    }

    exit-confirmation-open-close {
        spring damping-ratio=1.0 stiffness=560 epsilon=0.01
    }

    screenshot-ui-open {
        duration-ms 220
        curve "cubic-bezier" 0.22 1.0 0.36 1.0
    }

    overview-open-close {
        // Overview should feel smooth and premium, not springy/bouncy.
        spring damping-ratio=1.0 stiffness=620 epsilon=0.0001
    }

    recent-windows-close {
        spring damping-ratio=1.0 stiffness=680 epsilon=0.001
    }
}
